rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /trips/{tripId} {
      // ใครก็ได้ที่ login แล้วอ่านได้
      allow read: if request.auth != null;

      // สร้าง trip ต้อง login + ownerUid ตรงกับตัวเอง
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;

      // แก้ไข: เจ้าของ หรือ สมาชิก หรือ trip เก่า
      allow update: if request.auth != null
                    && (
                      resource.data.ownerUid == request.auth.uid
                      || (resource.data.keys().hasAny(['memberUids'])
                          && request.auth.uid in resource.data.memberUids)
                      || !resource.data.keys().hasAny(['ownerUid'])
                    );

      // ลบได้เฉพาะเจ้าของ หรือ trip เก่า
      allow delete: if request.auth != null
                    && (
                      resource.data.ownerUid == request.auth.uid
                      || !resource.data.keys().hasAny(['ownerUid'])
                    );
    }
  }
}
